# Copy this file to `.env` (which is gitignored) and fill in the three values.
#
# The bucket MUST have Uniform Bucket-Level Access OFF (fine-grained ACLs) —
# the server verifies this at startup and refuses to run otherwise.
# See plans/initial-build/build/requirements.md → "Operator Setup" for the
# exact gcloud commands to create the bucket, service account, and key.

# Bucket name only (no gs:// prefix), e.g. my-artifacts-bucket
GCS_BUCKET=

# GCP project id, e.g. my-project-123456
GCS_PROJECT_ID=

# ABSOLUTE path to the service-account JSON key.
# Recommended location (gitignored): secrets/gcs-sa-key.json
# e.g. /home/bobby/rigs/static-hosting-mcp/secrets/gcs-sa-key.json
GOOGLE_APPLICATION_CREDENTIALS=
