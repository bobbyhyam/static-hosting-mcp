# Copy this file to `.env` (which is gitignored) and fill in the values.
#
# The bucket MUST use fine-grained access (Uniform Bucket-Level Access OFF) so the
# server can grant per-recipient read access via per-object ACLs. On startup the
# server validates that the credentials load and the bucket is reachable; it does
# NOT check the UBLA setting then. If UBLA is on, the first grant (on publish or
# grant_access) fails with an actionable error telling you to disable it.
# See README.md and plans/initial-build/build/requirements.md → "Operator Setup"
# for the exact gcloud commands to create the bucket, service account, and key.

# Bucket name only (no gs:// prefix), e.g. my-artifacts-bucket
GCS_BUCKET=

# GCP project id, e.g. my-project-123456
GCS_PROJECT_ID=

# ABSOLUTE path to the service-account JSON key.
# Recommended location (gitignored): secrets/gcs-sa-key.json
# e.g. /home/bobby/rigs/static-hosting-mcp/secrets/gcs-sa-key.json
GOOGLE_APPLICATION_CREDENTIALS=

# OPTIONAL — publish_artifact source_path controls.
#
# publish_artifact can upload a local file named by `source_path`. Because an
# uploaded artifact can be shared with external Google accounts in the same call,
# reading local files is DENIED BY DEFAULT (publish inline `content` instead). To
# enable it, set ARTIFACT_SOURCE_ROOT to the ABSOLUTE directory your artifacts live
# in; only files that resolve INSIDE that directory may be read. Symlinks that
# escape it, the service-account key, files under any `secrets/` directory, ~/.ssh,
# ~/.config/gcloud, and *.pem / *.key files are always refused — so a caller can
# never turn source_path into a "read the SA key, publish it, share it" channel.
# Leave unset to disable source_path entirely.
# e.g. /home/bobby/rigs/static-hosting-mcp/artifacts
ARTIFACT_SOURCE_ROOT=

# OPTIONAL — maximum artifact size in bytes (inline content OR a source_path file).
# Default: 104857600 (100 MiB). A larger file is refused from a stat, before it is
# read into memory.
ARTIFACT_MAX_BYTES=
