# Copy this file to `.env` (which is gitignored) and fill in the values.
#
# The bucket MUST use fine-grained access (Uniform Bucket-Level Access OFF) so the
# server can grant per-recipient read access via per-object ACLs. On startup the
# server validates that the credentials load and the bucket is reachable; it does
# NOT check the UBLA setting then. If UBLA is on, the first grant (on publish or
# grant_access) fails with an actionable error telling you to disable it.
# See README.md and plans/initial-build/build/requirements.md → "Operator Setup"
# for the exact gcloud commands to create the bucket, service account, and key.

# Bucket name only (no gs:// prefix), e.g. my-artifacts-bucket
GCS_BUCKET=

# GCP project id, e.g. my-project-123456
GCS_PROJECT_ID=

# ABSOLUTE path to the service-account JSON key.
# Recommended location (gitignored): secrets/gcs-sa-key.json
# e.g. /home/bobby/rigs/static-hosting-mcp/secrets/gcs-sa-key.json
GOOGLE_APPLICATION_CREDENTIALS=
